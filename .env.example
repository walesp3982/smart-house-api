# General configuration
APP_NAME = "Smart House API"
APP_HOST = "http://localhost:8000/"
DEBUG = False
SQL_DEBUG = False
CORS_ORIGINS = ["localhost:3000", "localhost:8000"]  # List of allowed origins for CORS
VALIDATION_EMAIL = True  # Enable email validation for user registration

# Database configuration
DB_TYPE = mysql  # Accept mysql and sqlite
DB_HOST = localhost # Url of sgdb
DB_PORT = 3306 # Port of sgdb
DB_USER = root # Name of user to sgdb
DB_PASSWORD = PASSWORD # Password of user
DB_NAME_DB = my_database # Name of Databases


# Broker MQTT configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_KEEPALIVE=60
MQTT_CLIENT_ID=smart-house-api
# JWT configuration
# NOTA: user secrets.token_hex([32]) para generar un secreto de 32 bytes en hexadecimal
JWT_SECRET_KEY=
JWT_EXPIRATION_MINUTES=30

# Configuración de SMTP 
# Configuración ejemplo con mailpit (cambiar si vas a usar otro proveedor de correo)
EMAIL_SERVER = "localhost"
EMAIL_PORT = 1025
EMAIL_USERNAME = "smart-house@gmail.com"
EMAIL_PASSWORD = ""
EMAIL_STARTTLS = False
EMAIL_SSL_TLS = False
EMAIL_USE_CREDENTIALS = False
EMAIL_FROM = "smart-house@gmail.com"